# Sample environment for the prediction-market services on EC2.
# Copy this file to /etc/prediction-market.env on each instance and fill
# in the placeholders. Keep secrets out of the source tree.

# ----- Required everywhere -----
DSQL_HOST=replace-me.dsql.us-east-2.on.aws
AWS_REGION=us-east-2

# ----- Listener (only needed on listener boxes) -----
CLIENT_LISTENER_HOST=0.0.0.0
CLIENT_LISTENER_PORT=9000
# In production prefer aws-secretsmanager; fall back to static-token only for dev.
CLIENT_LISTENER_AUTH_MODE=aws-secretsmanager
CLIENT_LISTENER_AUTH_SECRET_ARN=arn:aws:secretsmanager:us-east-2:000000000000:secret:prod/prediction-market/listener-auth
# CLIENT_LISTENER_AUTH_TOKEN=  # only used when AUTH_MODE=static-token
CLIENT_LISTENER_WORKERS=2
CLIENT_LISTENER_DB_MIN_POOL=8
CLIENT_LISTENER_DB_MAX_POOL=64
CLIENT_LISTENER_METRICS_PORT=9101
CLIENT_LISTENER_ACCOUNT_SESSION_TTL_SECONDS=43200

# ----- Matchmaker (only needed on the worker box) -----
# Set MATCHMAKER_INSTANCE_INDEX/MATCHMAKER_TOTAL_INSTANCES if running >1
# matcher process across boxes for consistent-hash market sharding.
MATCHMAKER_INSTANCE_ID=matcher-prod-a
MATCHMAKER_INSTANCE_INDEX=0
MATCHMAKER_TOTAL_INSTANCES=1
MATCHMAKER_POLL_INTERVAL_MS=200
MATCHMAKER_MARKET_SCAN_LIMIT=50
MATCHMAKER_REQUEUE_INTERVAL_MS=5000
MATCHMAKER_METRICS_PORT=9111

# ----- Executor (only needed on the worker box) -----
EXECUTOR_INSTANCE_ID=executor-prod-a
EXECUTOR_POLL_INTERVAL_MS=1000
EXECUTOR_MARKET_SCAN_LIMIT=50
